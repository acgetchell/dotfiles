# Allow repository notebook workflows to run outside the sandbox so Jupyter can
# bind local kernel ports while keeping normal workspace-write filesystem limits.
prefix_rule(
    pattern = ["just", ["notebook", "notebook-check", "notebook-execute", "notebook-execute-all"]],
    decision = "allow",
    justification = "Jupyter notebook workflows need local kernel socket binding; keep this scoped to notebook just recipes.",
    match = [
        "just notebook",
        "just notebook-check",
        "just notebook-execute",
        "just notebook-execute-all",
    ],
    not_match = [
        "just notebook-output-check",
        "just notebook-clear-outputs-all",
        "just ci",
        "just check",
        "jupyter lab notebooks/00_quickstart.ipynb",
    ],
)
